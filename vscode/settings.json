{
    // Latex Workshop
    "latex-workshop.latex.recipes": [
        {
            "name": "lualatex",
            "tools": [
                "lualatex" // "latex-workshop.latex.tools"で指定するtoolsを使う
            ]
        }
    ],
    "latex-workshop.latex.tools": [
        {
            "name": "lualatex", // 任意
            "command": "lualatex", // エンジン指定
            "args": [ // 実行オプション
                "--cmdx", // 日本語ファイル名対応
                "-file-line-error", // エラー箇所
                "-synctex=1", 
                "-interaction=nonstopmode", // コンパイル中のエラーでも続行
                "-halt-on-error", // コンパイル中のエラーたら中止
                "-output-directory=%OUTDIR%", // 出力先の指定
                "%DOC%" // .texのパス
            ],
            "env": {}
        }
    ],
    "latex-workshop.latex.outDir": "",  // 出力先の指定
    "latex-workshop.latex.autoBuild.run": "onSave", // ビルドのタイミング
//     "latex-workshop.latex.clean.fileTypes": [
